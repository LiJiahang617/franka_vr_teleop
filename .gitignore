# Ignore Python cache and compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore virtual environments
.venv/
venv/
env/

# Ignore build and distribution folders
build/
dist/
*.egg-info/

# Ignore Jupyter notebook checkpoints
.ipynb_checkpoints/

# Ignore VSCode and IDE configs
.vscode/
.idea/

# === 通用日志 / 备份 / 数据缓存 ===
*.log
*.bak
*.bak.*
*.bak-*
*.npz
*.csv
_*.log

# === 私有标定数据 (用户本机生成, 不入库) ===
.stage3_*.npy
.stage3_*.json
.stage3_*.meta.json
_payload_ident_v2_out_*.npz

# === 数采产物 ===
_hdf5_episodes/
_lerobot_out/
_stage3_*
recordings/*.h5
recordings/**/*.h5
tmp/

# === 可视化输出 ===
*.rrd

# === 运行时服务日志 ===
_polymetis_*.log
_gripper_*.log

# 录制数据 (整目录, 含 .h5/.parquet/.mp4/.json/.jsonl)
/recordings/
/_payload_ident_v2_out_*.npz

# 用户本机路径 env (run_ui.sh 自动加载)
.env
