# Franka VR Teleop env vars
# 用法二选一:
#   (1) export 到 ~/.bashrc 一次性永久生效 (推荐)
#   (2) cp .env.example .env 改成你的真实路径, scripts/run_ui.sh 会自动 source
# 注意: 同时存在时 .env 覆盖 ~/.bashrc 的 export 值

# Polymetis conda env 根 (用于 controller_preflight 启 joint impedance subprocess)
POLYMETIS_ENV=/home/ubuntu/Desktop/jhli/envs/polymetis-local

# Polymetis 源码根 (含 polymetis/polymetis/python/scripts/launch_*.py)
POLYMETIS_SOURCE=/home/ubuntu/Desktop/jhli/fairo-franka

# 采集侧 venv 根 (run_record_hdf5_ui.py 用此 python 跑; 不是 conda)
FRANKA_TELEOP_VENV=/home/ubuntu/Desktop/jhli/envs/franka-teleop
